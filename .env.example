# Copy this file to .env for local development.
# In Vercel, set these under Project Settings > Environment Variables instead
# (never commit real secrets, and never prefix these with VITE_ or they'd be
# bundled into client-side JS).

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=a-long-random-string-used-to-sign-app-login-tokens
